#!/usr/bin/env bash
# Convenience wrapper for vendor/bin/easeo-doctor (provided by easeo/cms-core).
# Run this from the site root: ./bin/easeo-doctor
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SITE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ ! -x "$SITE_ROOT/vendor/bin/easeo-doctor" ]; then
  echo "easeo-doctor not installed yet — run 'composer install' first."
  echo "(Doctor will be shipped by easeo/cms-core in Plan 12.)"
  exit 1
fi

exec "$SITE_ROOT/vendor/bin/easeo-doctor" "$@"
