# easeo/cms-core — environment-backed secrets
#
# Copy to .env (gitignored) and fill in values.
# Public/branding config lives in data/site.config.json (editable via /beheer/).

# SMTP (used by Mailer when configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_ENCRYPTION=ssl

# Tracking
GTM_ID=

# Payments (optional — only if a Payment module is enabled)
MOLLIE_API_KEY=
