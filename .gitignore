# EASEO CMS — Git ignore

# Data files (contain site-specific content)
data/*.json
data/audit.log
data/audit.log.old
data/submissions/
!data/.htaccess
!data/.gitkeep

# Login attempts
data/login_attempts.json

# Uploaded media
images/uploads/*
images/thumbs/*
!images/uploads/.gitkeep
!images/thumbs/.gitkeep

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# Composer
composer.phar
/vendor/
/apps/*/vendor/
/packages/*/vendor/
composer.lock

# Env
/apps/*/.env

# Build / tests
.phpunit.result.cache
coverage/

# PHPUnit result cache
.phpunit.cache/
